# Global settings
dryRun: false

sonarr:
  - name: "Local Sonarr"
    url: "http://localhost:8989"
    apiKey: "YOUR_SONARR_API_KEY"
    pathMappings:
      - remote: "/media"
        local: "/mnt/media"

radarr:
  - name: "Local Radarr"
    url: "http://localhost:7878"
    apiKey: "YOUR_RADARR_API_KEY"
    pathMappings:
      - remote: "/media"
        local: "/mnt/media"

qbittorrent:
  - name: "Seedbox"
    url: "http://localhost:8080"
    username: "admin"
    password: "adminadmin"
    readOnly: false
    pathMappings:
      - remote: "/downloads/"
        local: "/mnt/user/downloads/"

scoring:
  maxSize: "10GB"
  maxRatio: "100MiB/min"
  maxBitrate: "10Mbit"
  minSeedDuration: "336h" # 2 weeks

automation:
  # Cron expression for background tasks (Incremental scan)
  # Example: "7 4 * * *" runs every day at 04:07 AM
  # Leave empty to disable
  schedule: ""

  # Enable automatic deletion and upgrade of candidates without confirmation
  autoUpgrade: false

  # Minimum size reduction required to trigger auto-upgrade (e.g. percentage "10%" or absolute size "500MiB")
  minSizeReduction: "10%"

  # Minimum seeders required for a candidate release torrent to be grabbed
  minSeeders: 3

  # Maximum Arr searches triggered per hour
  rateLimit: 6
